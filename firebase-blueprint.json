{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Thông tin người dùng cá nhân",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "currency": { "type": "string", "enum": ["VND", "USD", "EUR"] },
        "approved": { "type": "boolean", "description": "Trạng thái phê duyệt bởi admin" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uid", "email", "approved", "role"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Giao dịch tài chính (thu nhập hoặc chi phí)",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner UID" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "note": { "type": "string" },
        "attachmentUrl": { "type": "string", "description": "URL of uploaded receipt/file" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "amount", "type", "category", "date"]
    },
    "Category": {
      "title": "Category",
      "description": "Danh mục chi tiêu/thu nhập",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] }
      },
      "required": ["uid", "name", "type"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Thông tin hồ sơ người dùng"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Danh sách các giao dịch"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Danh mục tùy chỉnh của người dùng"
    }
  }
}
